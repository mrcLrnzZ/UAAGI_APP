<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/education_entry_background"
    android:layout_marginBottom="12dp">

    <!-- Level and School -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewEducationLevel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- School -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="School: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewEducationSchool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Year Graduated -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Year Graduated: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewEducationYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewEducationStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Achievement -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Achievement: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewEducationAchievement"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
