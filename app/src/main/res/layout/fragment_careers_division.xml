<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White"
    tools:context=".ui.users.FragmentsCareers.JobsOption">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/White">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/PaleBlue">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/LightBlue"
                    android:layout_gravity="start"/>

                <View
                    android:layout_width="85dp"
                    android:layout_height="85dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.35"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-18dp"
                    android:layout_marginEnd="-18dp"/>

                <View
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.18"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="30dp"
                    android:layout_marginEnd="20dp"/>

                <View
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.20"
                    android:layout_gravity="bottom|start"
                    android:layout_marginBottom="-18dp"
                    android:layout_marginStart="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="26dp"
                        android:paddingBottom="20dp">

                        <TextView
                            android:id="@+id/tvCompanyBrand"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FOTON PHILIPPINES"
                            android:textColor="@color/LightBlue"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="5dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Innovate with us"
                            android:textColor="@color/DarkBlue"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvCompanySlogan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Build your career with Foton Philippines."
                            android:textColor="@color/LightBlue"
                            android:textSize="11sp"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginBottom="16dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:background="@color/White"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="14dp"
                                android:src="@drawable/vectorsearch"
                                app:tint="@color/Gray"/>

                            <EditText
                                android:id="@+id/search_division"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="14dp"
                                android:background="@android:color/transparent"
                                android:hint="Search Division"
                                android:textColorHint="@color/LightGray"
                                android:textColor="@color/DarkBlue"
                                android:textSize="13sp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="20dp"
                        android:background="@color/PaleBlue"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">


                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIVISIONS"
                    android:textColor="@color/Gray"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="2dp"/>

                <FrameLayout
                    android:id="@+id/loading_container"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"/>

                <FrameLayout
                    android:id="@+id/error_container"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/division_container"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>