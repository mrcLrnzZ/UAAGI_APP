<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/WhiteSmoke"
    tools:context=".ui.users.FragmentsHomePage.Careers">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/WhiteSmoke">

            <!-- ── Header ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/DarkBlue"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OUR BRANDS"
                    android:textColor="@color/LightBlue"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Know Our Brands — Start the Journey"
                    android:textColor="@color/White"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Be part of a team driving innovation in the automotive industry."
                    android:textColor="@color/LightGray"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>

            <!-- ── Cards Section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FEATURED BRANDS"
                    android:textColor="@color/Gray"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="2dp"/>

                <!-- ── FOTON CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/fotonBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPicture"
                                            android:layout_width="28dp"
                                            android:layout_height="32dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/foton"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Foton Philippines Inc."
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-black"
                                        android:letterSpacing="0.01"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDesc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="11sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Foton Motor Philippines, Inc. is a leading automotive manufacturer known for quality vehicles and a commitment to innovation."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/pin"
                                app:tint="@color/Deepwater"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/Deepwater"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── CHERY CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cheryBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureCHERY"
                                            android:layout_width="28dp"
                                            android:layout_height="28dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/cherylogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameCHERY"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Chery Auto Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-black"
                                        android:letterSpacing="0.01"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescCHERY"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="11sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionCHERY"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chery Auto Philippines is a fast-growing automotive company bringing innovative and quality vehicles to the Philippine market."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/pin"
                                app:tint="@color/Deepwater"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/Deepwater"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── BAIC CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/baicBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureBAIC"
                                            android:layout_width="28dp"
                                            android:layout_height="28dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/baiclogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameBAIC"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="BAIC Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-black"
                                        android:letterSpacing="0.01"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescBAIC"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="11sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionBAIC"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="BAIC Philippines is a trusted automotive brand delivering value-driven vehicles to Filipino customers."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/pin"
                                app:tint="@color/Deepwater"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/Deepwater"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── LYNK & CO CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/lynkcoBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureLynkco"
                                            android:layout_width="28dp"
                                            android:layout_height="28dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/lynkco"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameLynkco"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Lynk and Co Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-black"
                                        android:letterSpacing="0.01"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescLynkco"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="11sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionLynkco"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Lynk and Co Philippines is a modern automotive brand redefining mobility."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/pin"
                                app:tint="@color/Deepwater"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/Deepwater"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ── MUTT CARD ── -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/muttBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/WhiteSmoke"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:background="@color/LightGray"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="36dp"
                                        android:layout_height="36dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureMutt"
                                            android:layout_width="28dp"
                                            android:layout_height="28dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/muttlogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameMUTT"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Mutt Motorcycles Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="15sp"
                                        android:fontFamily="sans-serif-black"
                                        android:letterSpacing="0.01"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescMUTT"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="11sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionMUTT"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mutt Motorcycle Philippines brings custom style and modern performance."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/pin"
                                app:tint="@color/Deepwater"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/Deepwater"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>