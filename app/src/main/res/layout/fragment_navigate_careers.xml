<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White"
    tools:context=".ui.users.FragmentsCareers.CompanyOptions">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HERO BANNER ── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/PaleBlue">

                <View
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.3"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-20dp"
                    android:layout_marginEnd="-20dp"/>

                <View
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.18"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="35dp"
                    android:layout_marginEnd="18dp"/>

                <View
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.20"
                    android:layout_gravity="bottom|start"
                    android:layout_marginBottom="-20dp"
                    android:layout_marginStart="-20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingTop="32dp"
                    android:paddingEnd="24dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.14"
                        android:text="CAREERS"
                        android:textColor="@color/LightBlue"
                        android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Explore \nOpportunities"
                        android:textColor="@color/DarkBlue"
                        android:textSize="26sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="3dp"
                        android:text="Opportunities available for interns and workers."
                        android:textColor="@color/LightBlue"
                        android:textSize="13sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ── CARDS SECTION ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BROWSE BY TYPE"
                    android:textColor="@color/Gray"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="2dp"/>

                <!-- Internship Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/InternShip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/internCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:minHeight="110dp">

                        <!-- Left accent panel -->
                        <LinearLayout
                            android:layout_width="88dp"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/PaleBlue"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/education"
                                app:tint="@color/LightBlue"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OJT"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:letterSpacing="0.06"
                                android:fontFamily="sans-serif-black"/>
                        </LinearLayout>

                        <!-- Right content -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/careerTypeIntern"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Internship"
                                android:textColor="@color/DarkBlue"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/internDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OJT programs for students and fresh graduates."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"
                                android:layout_marginBottom="14dp"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/PaleBlue"
                                android:layout_marginBottom="11dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="View Openings"
                                    android:textColor="@color/LightBlue"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-black"/>

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/arrowright"
                                    app:tint="@color/DarkBlue"
                                    android:layout_marginEnd="4dp"/>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Job Openings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/JobOpportunities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/jobCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:minHeight="110dp">

                        <!-- Left accent panel -->
                        <LinearLayout
                            android:layout_width="88dp"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#E6EDF8"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/briefcase"
                                app:tint="@color/DarkBlue"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FULL-TIME"
                                android:textColor="@color/DarkBlue"
                                android:textSize="9sp"
                                android:letterSpacing="0.04"
                                android:fontFamily="sans-serif-black"/>
                        </LinearLayout>

                        <!-- Right content -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/careerTypeJob"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Job Openings"
                                android:textColor="@color/DarkBlue"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/jobDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Full-time and field work career opportunities."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="3dp"
                                android:layout_marginBottom="14dp"/>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/PaleBlue"
                                android:layout_marginBottom="11dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="View Openings"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-black"/>

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/arrowright"
                                    app:tint="@color/DarkBlue"
                                    android:layout_marginEnd="4dp"/>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Info strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/PaleBlue"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/LightBlue"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tap a card to see available slots and requirements."
                        android:textColor="@color/Deepwater"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>