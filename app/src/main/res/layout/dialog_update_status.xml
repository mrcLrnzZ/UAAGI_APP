<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0F">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="240dp"
        app:cardBackgroundColor="@color/White"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.55">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/accentBar"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:background="@color/DarkBlue"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Close Button -->
            <ImageView
                android:id="@+id/ivCloseDialog"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:padding="8dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Close"
                app:tint="@color/DarkBlue"
                app:layout_constraintTop_toBottomOf="@id/accentBar"
                app:layout_constraintEnd_toEndOf="parent"
                android:clickable="true"
                android:focusable="true"/>


            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="12dp"
                android:paddingTop="20dp"
                android:text="Application status"
                android:textSize="22sp"
                android:textColor="@color/DarkBlue"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="0.01"
                app:layout_constraintTop_toBottomOf="@id/logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Status Badge -->
            <LinearLayout
                android:id="@+id/statusBadgeContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_approved_badge"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#3B6D11" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#3B6D11"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Subtitle/Label -->
            <TextView
                android:id="@+id/tvLabelDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INTERVIEW DETAILS"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.06"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/statusBadgeContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Details Container -->
            <LinearLayout
                android:id="@+id/detailsBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_outlined"
                app:layout_constraintTop_toBottomOf="@id/tvLabelDetails">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#185FA5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />
                        <TextView
                            android:id="@+id/interviewDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="March 15, 2026"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/clock"
                            app:tint="#185FA5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />
                        <TextView
                            android:id="@+id/interviewTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3:00 PM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/mode"
                            app:tint="#185FA5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mode"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In-person interview"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UAAGI Balintawak"
                            android:textSize="12sp"
                            android:textColor="#757575" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_blue"
                        android:layout_marginEnd="12dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/pin"
                            app:tint="#185FA5" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Balintawak"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quezon City, Philippines"
                            android:textSize="12sp"
                            android:textColor="#757575" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Separator -->
            <View
                android:id="@+id/separator"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginTop="24dp"
                android:background="@color/DarkBlue"
                android:alpha="0.4"
                app:layout_constraintTop_toBottomOf="@id/detailsBox"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="28dp"
                android:paddingHorizontal="24dp"
                android:paddingBottom="42dp"
                app:layout_constraintTop_toBottomOf="@id/separator"
                app:layout_constraintBottom_toBottomOf="parent">

                <Button
                    android:id="@+id/btnDecline"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Decline"
                    android:textSize="14sp"
                    android:textColor="#7A7A96"
                    android:background="@drawable/cancel_bg"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnReschedule"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1.6"
                    android:layout_marginStart="8dp"
                    android:text="RESCHEDULE"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/White"
                    android:letterSpacing="0.05"
                    android:background="@drawable/logout_bg"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>