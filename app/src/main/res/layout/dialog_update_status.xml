<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0F">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/White"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ── DARK HERO HEADER ── -->
            <FrameLayout
                android:id="@+id/dialogHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/DarkBlue"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="22dp"
                android:paddingBottom="28dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">



                <!-- Header content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Eyebrow + Close row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="APPLICATION STATUS"
                            android:textColor="@color/LightBlue"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-medium"/>

                        <ImageView
                            android:id="@+id/ivCloseDialog"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/circle_background_done"
                            android:src="@drawable/ic_close"
                            android:padding="7dp"
                            android:scaleType="centerInside"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/Deepwater"/>
                    </LinearLayout>

                    <!-- Title -->
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Interview Scheduled"
                        android:textColor="@color/White"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginBottom="4dp"/>

                    <!-- Subtitle — company + job -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Foton Philippines · Junior Web Developer"
                        android:textColor="@color/LightBlue"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:id="@+id/statusBadgeContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_approved_badge"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:visibility="invisible"
                        android:paddingTop="5dp"
                        android:paddingBottom="5dp">

                        <ImageView
                            android:id="@+id/ivStatusIcon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            app:tint="#97C459"/>

                        <TextView
                            android:id="@+id/tvApplicationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Approved"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#C0DD97"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/dialogBody"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp"
                app:layout_constraintTop_toBottomOf="@id/dialogHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tvLabelDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTERVIEW DETAILS"
                    android:textSize="9sp"
                    android:textColor="@color/Gray"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/detailsBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/infoBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="visible">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="15dp"
                                        android:layout_height="15dp"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="@color/LightBlue"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Date"
                                        android:textSize="9sp"
                                        android:textColor="@color/Gray"
                                        android:fontFamily="sans-serif-medium"/>
                                    <TextView
                                        android:id="@+id/interviewDate"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="March 15, 2026"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/DarkBlue"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0.5dp"
                                android:background="@color/PaleBlue"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="15dp"
                                        android:layout_height="15dp"
                                        android:src="@drawable/clock"
                                        app:tint="@color/LightBlue"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Time"
                                        android:textSize="9sp"
                                        android:textColor="@color/Gray"
                                        android:fontFamily="sans-serif-medium"/>
                                    <TextView
                                        android:id="@+id/interviewTime"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="3:00 PM"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/DarkBlue"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="0.5dp"
                                android:background="@color/PaleBlue"/>

                            <!-- Mode row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="12dp">
                                    <ImageView
                                        android:layout_width="15dp"
                                        android:layout_height="15dp"
                                        android:src="@drawable/mode"
                                        app:tint="@color/LightBlue"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Mode"
                                        android:textSize="9sp"
                                        android:textColor="@color/Gray"
                                        android:fontFamily="sans-serif-medium"/>
                                    <TextView
                                        android:id="@+id/tvModeInterview"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="In-person Interview"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/DarkBlue"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/infoRejectBox"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="#FDECEA"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/tvPlaceOfInterview"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Balintawak, Quezon City"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:id="@+id/separator"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/PaleBlue"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnDecline"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Decline"
                        android:textSize="12sp"
                        android:textColor="@color/Gray"
                        android:background="@drawable/cancel_bg"
                        android:stateListAnimator="@null"/>

                    <Button
                        android:id="@+id/btnReschedule"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1.6"
                        android:layout_marginStart="8dp"
                        android:text="RESCHEDULE"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/White"
                        android:letterSpacing="0.05"
                        android:background="@drawable/logout_bg"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>