<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White"
    tools:context=".ui.users.FragmentsHomePage.Profile">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <RelativeLayout
                    android:id="@+id/layoutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"/>

                <LinearLayout
                    android:id="@+id/cardProfileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@id/layoutHeader"
                    android:background="@color/White"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="48dp"
                    android:paddingBottom="36dp">

                    <LinearLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:gravity="center"
                        android:background="@drawable/circle_background_done"
                        android:backgroundTint="#0AFFC107"
                        android:layout_marginBottom="32dp">

                        <LinearLayout
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:gravity="center"
                            android:background="@drawable/circle_background_done"
                            android:backgroundTint="#1AFFC107">

                            <LinearLayout
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:gravity="center"
                                android:background="@drawable/circle_background_done"
                                android:backgroundTint="#FFF8E1">

                                <ImageView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/exclamation"
                                    android:scaleType="fitCenter"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="Already Sent!"
                        android:textColor="@color/DarkBlue"
                        android:textSize="26sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="You already sent your application for this position."
                        android:textColor="@color/Gray"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="40dp"/>


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp"
                        app:cardBackgroundColor="@color/White"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/LightGray"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="top"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:gravity="center"
                                android:background="@drawable/circle_background_done"
                                android:backgroundTint="#FFF8E1"
                                android:layout_marginEnd="14dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_info"
                                    app:tint="@color/LightBlue"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif-black"
                                    android:text="What happens next"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="14sp"
                                    android:layout_marginBottom="5dp"/>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="You will get an email confirmation or see updated status at My Applications."
                                    android:textColor="@color/Gray"
                                    android:textSize="13sp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/LightGray"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:id="@+id/JobPosition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Keep track of your applications in your Applied Jobs dashboard."
                        android:textColor="@color/LightGray"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>