<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/education_entry_background"
    android:layout_marginBottom="12dp">

    <!-- Name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewCertName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Organization -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organization: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewCertOrganization"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewCertDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Expiry Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expiry Date: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewCertExpiry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description: "
            android:fontFamily="sans-serif-medium"
            android:textColor="#757575"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvPreviewCertDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="—"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
