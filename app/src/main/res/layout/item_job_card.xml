<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/jobCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/White"
    app:strokeColor="@color/PaleBlue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Card Body ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Logo + Title + Actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Title + Company -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvJobTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Job Title"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/DarkBlue"
                        android:textSize="15sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/tvCompany"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Company Name"
                        android:textColor="@color/Gray"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Bookmark / Like -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/WhiteSmoke"
                        android:gravity="center">
                        <ImageView
                            android:id="@+id/ivBookmark"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/baseline_bookmark_24"
                            android:scaleType="fitCenter"
                            app:tint="@color/LightBlue"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@color/WhiteSmoke"
                        android:gravity="center"
                        android:layout_marginStart="7dp">
                        <ImageView
                            android:id="@+id/ivLike"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/archive"
                            app:tint="@color/LightBlue"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Tags row 1 — Salary + Job Type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="7dp">

                <TextView
                    android:id="@+id/tvSalary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Salary"
                    android:textColor="@color/DarkBlue"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvJobType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Job Type"
                    android:textColor="@color/DarkBlue"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="6dp"/>

            </LinearLayout>

            <!-- Tags row 2 — Experience + Shift + PayTag -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvExperienceLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Experience"
                    android:textColor="@color/DarkBlue"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvShift"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Shift"
                    android:textColor="@color/DarkBlue"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvPayTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="Pay Tag"
                    android:textColor="@color/DarkBlue"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Location Footer Strip ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/PaleBlue"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/pin"
                android:tint="@color/LightBlue"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location"
                android:textColor="@color/LightBlue"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>