<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    android:layout_marginBottom="4dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@color/White">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:id="@+id/layoutResponseWarning"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/warning_badge_background"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:gravity="center"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Response seems unlikely"
                        android:textSize="11sp"
                        android:textColor="@color/DarkBlue"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/ic_info"
                        android:layout_marginStart="4dp"
                        app:tint="@color/DarkBlue" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivMenuDots"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_more_vert"
                    android:layout_alignParentEnd="true"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:visibility="gone"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/Gray" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvCompanyName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Company Name"
                android:textSize="11sp"
                android:textColor="@color/LightBlue"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvJobTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Job Title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/DarkBlue"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="@color/LightBlue"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/pin"
                    app:tint="@color/DarkBlue" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textSize="13sp"
                    android:textColor="@color/Gray"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/DarkBlue" />

                <TextView
                    android:id="@+id/tvAppliedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Applied on"
                    android:textSize="12sp"
                    android:textColor="@color/Gray"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnUpdateStatus"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Update status"
                android:textSize="13sp"
                android:textColor="@color/White"
                android:textAllCaps="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/update_status_button_background"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutEmployerResponse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/PaleBlue"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_flash"
                    app:tint="@color/Deepwater" />

                <TextView
                    android:id="@+id/tvEmployerResponse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This employer typically responds within 1 day"
                    android:textSize="12sp"
                    android:textColor="@color/Deepwater"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>