<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White"
    tools:context=".ui.users.FragmentsCareers.CompanyOptions">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/White">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/PaleBlue">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/LightBlue"
                    android:layout_gravity="start"/>

                <View
                    android:layout_width="85dp"
                    android:layout_height="85dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.35"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-18dp"
                    android:layout_marginEnd="-18dp"/>

                <View
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.18"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="30dp"
                    android:layout_marginEnd="20dp"/>

                <View
                    android:layout_width="65dp"
                    android:layout_height="65dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.20"
                    android:layout_gravity="bottom|start"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="26dp"
                        android:paddingBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OUR BRANDS"
                            android:textColor="@color/LightBlue"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-black"
                            android:layout_marginBottom="5dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Know Our Brands — Start the Journey"
                            android:textColor="@color/DarkBlue"
                            android:textSize="19sp"
                            android:fontFamily="sans-serif-black"
                            android:lineSpacingExtra="2dp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Be part of a team driving innovation in the automotive industry."
                            android:textColor="@color/LightBlue"
                            android:textSize="11sp"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginBottom="14dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@color/White"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-black"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Brands"
                                    android:textColor="@color/LightBlue"
                                    android:textSize="9sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="14dp"
                                android:background="@color/LightBlue"
                                android:layout_marginStart="8dp"
                                android:layout_marginEnd="8dp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@color/White"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="80"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-black"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Countries"
                                    android:textColor="@color/LightBlue"
                                    android:textSize="9sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/DarkBlue"
                        android:paddingStart="24dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/circle_background"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lifestyle · Utility · Innovation"
                            android:textColor="@color/LightBlue"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-medium"/>

                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FEATURED BRANDS"
                    android:textColor="@color/Gray"
                    android:textSize="10sp"
                    android:letterSpacing="0.14"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="2dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/fotonBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPicture"
                                            android:layout_width="52dp"
                                            android:layout_height="52dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/foton"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Foton Philippines Inc."
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-black"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDesc"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Foton Motor Philippines, Inc. is a leading automotive manufacturer known for quality vehicles and a commitment to innovation."
                                android:textColor="@color/Gray"
                                android:textSize="11sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"/>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/arrowright"
                                app:tint="@color/LightBlue"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cheryBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureCHERY"
                                            android:layout_width="52dp"
                                            android:layout_height="52dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/cherylogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameCHERY"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Chery Auto Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-black"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescCHERY"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionCHERY"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chery Auto Philippines is a fast-growing automotive company bringing innovative and quality vehicles to the Philippine market."
                                android:textColor="@color/Gray"
                                android:textSize="11sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"/>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/arrowright"
                                app:tint="@color/LightBlue"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/baicBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureBAIC"
                                            android:layout_width="52dp"
                                            android:layout_height="52dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/baiclogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameBAIC"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="BAIC Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-black"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescBAIC"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionBAIC"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="BAIC Philippines is a trusted automotive brand delivering value-driven vehicles to Filipino customers."
                                android:textColor="@color/Gray"
                                android:textSize="11sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"/>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/arrowright"
                                app:tint="@color/LightBlue"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/lynkcoBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureLynkco"
                                            android:layout_width="52dp"
                                            android:layout_height="52dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/lynkco"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameLynkco"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Lynk and Co Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-black"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescLynkco"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionLynkco"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Lynk and Co Philippines is a modern automotive brand redefining mobility."
                                android:textColor="@color/Gray"
                                android:textSize="11sp"
                                android:lineSpacingExtra="3dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/PaleBlue"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="9dp"
                            android:paddingBottom="9dp">

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Quezon, Philippines"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"/>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/arrowright"
                                app:tint="@color/LightBlue"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/muttBrandCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/PaleBlue"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="10dp">

                                <LinearLayout
                                    android:layout_width="52dp"
                                    android:layout_height="52dp"
                                    android:gravity="center"
                                    android:layout_marginEnd="12dp">

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="52dp"
                                        android:layout_height="52dp"
                                        app:cardCornerRadius="9dp"
                                        app:cardBackgroundColor="@color/White"
                                        app:cardElevation="2dp">

                                        <ImageView
                                            android:id="@+id/brandPictureMutt"
                                            android:layout_width="52dp"
                                            android:layout_height="52dp"
                                            android:layout_gravity="center"
                                            android:scaleType="fitCenter"
                                            android:src="@drawable/muttlogo"/>
                                    </androidx.cardview.widget.CardView>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/brandNameMUTT"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Mutt Motorcycles Philippines"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="14sp"
                                        android:fontFamily="sans-serif-black"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/brandSubDescMUTT"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Largest Commercial Vehicle in Asia"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"/>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvDescriptionMUTT"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
