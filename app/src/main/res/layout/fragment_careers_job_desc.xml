<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/White">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/White">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/White"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <ImageButton
                        android:id="@+id/btnBack"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@color/White"
                        android:src="@drawable/baseline_arrow_back_24"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        app:tint="@color/DarkBlue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="JOB DETAILS"
                        android:textColor="@color/LightGray"
                        android:textSize="10sp"
                        android:letterSpacing="0.14"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"/>

                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvJobTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Junior Web Developer"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/DarkBlue"
                    android:textSize="21sp"
                    android:lineSpacingExtra="2dp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvCompany"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Foton Philippines"
                    android:textColor="@color/Gray"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/White"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:src="@drawable/pin"
                            app:tint="@color/Deepwater"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quezon City, Philippines"
                            android:textColor="@color/Deepwater"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnBookmark"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@color/PaleBlue"
                        android:src="@drawable/bookmark"
                        android:padding="10dp"
                        android:layout_marginEnd="8dp"
                        android:scaleType="centerInside"
                        app:tint="@color/Deepwater"/>

                    <ImageButton
                        android:id="@+id/btnBlock"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@color/PaleBlue"
                        android:src="@drawable/ban"
                        android:padding="10dp"
                        android:scaleType="centerInside"
                        app:tint="@color/Deepwater"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnApplyNow"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/job_desc_button"
                    android:text="Apply Now"
                    android:textColor="@color/White"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.02"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- Description / Qualifications / Perks card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Job Description -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvJobDescHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Job Description"
                                android:textColor="@color/DarkBlue"
                                android:fontFamily="sans-serif-black"
                                android:textSize="13sp"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvJobDesc"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="This position is ideal for fresh graduates..."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/LightGray"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>

                        <!-- Qualifications -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvQualificationsHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Qualifications"
                                android:textColor="@color/DarkBlue"
                                android:fontFamily="sans-serif-black"
                                android:textSize="13sp"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvQualifications"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• Bachelor's degree..."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/LightGray"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>

                        <!-- Perks -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tvPerksHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Perks and Benefits"
                                android:textColor="@color/DarkBlue"
                                android:fontFamily="sans-serif-black"
                                android:textSize="13sp"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tvPerks"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• Competitive salary..."
                                android:textColor="@color/Gray"
                                android:textSize="12sp"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/White"
                    app:strokeColor="@color/LightGray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@color/White"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp">


                            <TextView
                                android:id="@+id/tvJobSummaryHeader"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Job Summary"
                                android:textColor="@color/Deepwater"
                                android:fontFamily="sans-serif-black"
                                android:textSize="12sp"
                                android:letterSpacing="0.02"/>
                        </LinearLayout>

                        <!-- Division row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:background="@color/WhiteSmoke"
                                android:layout_marginEnd="14dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/building"
                                    app:tint="@color/Gray"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDivisionLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DIVISION"
                                    android:textColor="@color/LightGray"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.06"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginBottom="2dp"/>

                                <TextView
                                    android:id="@+id/tvDivisionValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="IT Department"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/LightGray"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:background="@color/WhiteSmoke"
                                android:layout_marginEnd="14dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/pin"
                                    app:tint="@color/Gray"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvWorkSetupLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="WORK SETUP"
                                    android:textColor="@color/LightGray"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.06"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginBottom="2dp"/>

                                <TextView
                                    android:id="@+id/tvWorkSetupValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="On-site only"
                                    android:textColor="@color/DarkBlue"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>