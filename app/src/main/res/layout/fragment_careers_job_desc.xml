<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/jobCard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/White"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scrollbars="none"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/content_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/White">

                <!-- ── HERO SECTION ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/PaleBlue">

                    <!-- Decorative circles -->
                    <View
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/circle_background"
                        android:alpha="0.3"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-20dp"
                        android:layout_marginEnd="-20dp"/>

                    <View
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/circle_background"
                        android:alpha="0.18"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="35dp"
                        android:layout_marginEnd="18dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="24dp">

                        <!-- Top bar: Back + Title + Spacer -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <ImageButton
                                android:id="@+id/btnBack"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@color/PaleBlue"
                                android:src="@drawable/baseline_arrow_back_24"
                                android:padding="8dp"
                                android:scaleType="centerInside"
                                app:tint="@color/DarkBlue"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="JOB DETAILS"
                                android:textColor="@color/LightBlue"
                                android:textSize="10sp"
                                android:letterSpacing="0.14"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="center"/>

                            <View
                                android:layout_width="36dp"
                                android:layout_height="36dp"/>
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:id="@+id/tvJobTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Junior Web Developer"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/DarkBlue"
                                android:textSize="22sp"
                                android:lineSpacingExtra="2dp"
                                android:layout_marginEnd="10dp"/>

                            <ImageButton
                                android:id="@+id/btnBookmark"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@color/White"
                                android:src="@drawable/baseline_bookmark_24"
                                android:padding="9dp"
                                android:layout_marginEnd="6dp"
                                android:scaleType="centerInside"
                                app:tint="@color/LightBlue"/>

                            <ImageButton
                                android:id="@+id/btnBlock"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@color/White"
                                android:src="@drawable/archive"
                                android:padding="9dp"
                                android:scaleType="centerInside"
                                app:tint="@color/LightBlue"/>
                        </LinearLayout>

                        <!-- Company -->
                        <TextView
                            android:id="@+id/tvCompany"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Foton Philippines"
                            android:textColor="@color/LightBlue"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginBottom="10dp"/>

                        <!-- Location row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="18dp">

                            <ImageView
                                android:layout_width="11dp"
                                android:layout_height="11dp"
                                android:src="@drawable/pin"
                                app:tint="@color/LightBlue"
                                android:layout_marginEnd="5dp"/>

                            <TextView
                                android:id="@+id/tvLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quezon City, Philippines"
                                android:textColor="@color/LightBlue"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <!-- Apply Now button -->
                        <Button
                            android:id="@+id/btnApplyNow"
                            android:layout_width="130dp"
                            android:layout_height="38dp"
                            android:background="@drawable/job_desc_button"
                            android:text="Apply Now"
                            android:textColor="@color/White"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.02"/>

                    </LinearLayout>
                </FrameLayout>

                <!-- ── CONTENT SECTION ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="32dp">

                    <!-- Description / Qualifications / Perks card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/White"
                        app:strokeColor="@color/PaleBlue"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Job Description -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/tvJobDescHeader"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Job Description"
                                    android:textColor="@color/DarkBlue"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:id="@+id/tvJobDesc"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="This position is ideal for fresh graduates..."
                                    android:textColor="@color/Gray"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/PaleBlue"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp"/>

                            <!-- Qualifications -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/tvQualificationsHeader"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Qualifications"
                                    android:textColor="@color/DarkBlue"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:id="@+id/tvQualifications"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="• Bachelor's degree..."
                                    android:textColor="@color/Gray"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/PaleBlue"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp"/>

                            <!-- Perks -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/tvPerksHeader"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Perks and Benefits"
                                    android:textColor="@color/DarkBlue"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="13sp"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:id="@+id/tvPerks"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="• Competitive salary..."
                                    android:textColor="@color/Gray"
                                    android:textSize="12sp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/White"
                        app:strokeColor="@color/PaleBlue"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Header -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@color/PaleBlue"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:id="@+id/tvJobSummaryHeader"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Job Summary"
                                    android:textColor="@color/DarkBlue"
                                    android:fontFamily="sans-serif-black"
                                    android:textSize="13sp"
                                    android:letterSpacing="0.02"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp">

                                <LinearLayout
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="14dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/building"
                                        app:tint="@color/LightBlue"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvDivisionLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="DIVISION"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"
                                        android:letterSpacing="0.06"
                                        android:fontFamily="sans-serif-medium"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/tvDivisionValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="IT Department"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="13sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/PaleBlue"
                                android:layout_marginStart="16dp"
                                android:layout_marginEnd="16dp"/>

                            <!-- Work Setup row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:paddingTop="14dp"
                                android:paddingBottom="14dp">

                                <LinearLayout
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:background="@color/PaleBlue"
                                    android:layout_marginEnd="14dp">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/pin"
                                        app:tint="@color/LightBlue"/>
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvWorkSetupLabel"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="WORK SETUP"
                                        android:textColor="@color/Gray"
                                        android:textSize="10sp"
                                        android:letterSpacing="0.06"
                                        android:fontFamily="sans-serif-medium"
                                        android:layout_marginBottom="2dp"/>

                                    <TextView
                                        android:id="@+id/tvWorkSetupValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="On-site only"
                                        android:textColor="@color/DarkBlue"
                                        android:textSize="13sp"
                                        android:fontFamily="sans-serif-medium"/>
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>