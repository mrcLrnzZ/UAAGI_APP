<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/White"
    app:strokeColor="@color/PaleBlue"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCompanyName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tiger Global Business Services Inc."
                        android:textSize="10sp"
                        android:textColor="@color/Gray"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_marginBottom="3dp"/>

                    <TextView
                        android:id="@+id/tvJobTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Intern - IT, Marketing, Finance, Admin and HR"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/Gray"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:lineSpacingExtra="2dp"/>
                </LinearLayout>

                <!-- Unarchive icon -->
                <LinearLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@color/WhiteSmoke"
                    android:gravity="center"
                    android:layout_marginStart="8dp">
                    <ImageView
                        android:id="@+id/ivLike"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/unarchive"
                        android:scaleType="fitCenter"
                        app:tint="@color/Gray"/>
                </LinearLayout>

                <!-- Menu dots -->
                <ImageView
                    android:id="@+id/ivMenuDots"
                    android:visibility="gone"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_more_vert"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_marginStart="4dp"
                    app:tint="@color/Gray"/>
            </LinearLayout>

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="@color/Gray"
                android:layout_marginBottom="12dp"/>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/pin"
                    app:tint="@color/Gray"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Madrigal Business Park"
                    android:textSize="12sp"
                    android:textColor="@color/Gray"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/Gray"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvAppliedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Applied on Indeed · Jan 23"
                    android:textSize="12sp"
                    android:textColor="@color/Gray"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>


            <Button
                android:id="@+id/btnUpdateStatus"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="View status"
                android:textSize="13sp"
                android:textColor="@color/White"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/update_status_button_background"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/WhiteSmoke"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/circle_background"
                android:layout_marginEnd="7dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Archived"
                android:textColor="@color/Gray"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feb–Mar Start · Remote"
                android:textColor="@color/Gray"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>