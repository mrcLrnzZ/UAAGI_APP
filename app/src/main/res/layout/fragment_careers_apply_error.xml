<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/DarkBlue"
    tools:context=".ui.users.FragmentsHomePage.Profile">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/DarkBlue"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:id="@+id/layoutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="40dp"
                    android:background="@color/DarkBlue"/>

                <LinearLayout
                    android:id="@+id/cardProfileInfo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@id/layoutHeader"
                    android:layout_marginTop="-150dp"
                    android:background="@drawable/profile_card"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="30dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="24dp">

                    <ImageView
                        android:layout_marginBottom="15dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:src="@drawable/failed"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="Your application has not been sent!"
                        android:textColor="@color/DarkBlue"
                        android:textSize="24sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        app:cardBackgroundColor="@color/White"
                        app:cardElevation="6dp"
                        app:strokeColor="@color/DarkBlue"
                        app:strokeWidth="1dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:text="There is an error submitting you application. Try again later or contact the company’s HR and always check your email at angelemiejane.bien@gmail.com"
                            android:textColor="@color/Black"
                            android:textAlignment="center"/>

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/JobPosition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:gravity="center"
                        android:text="Keep track of your applications in your Applied Jobs dashboard."
                        android:textColor="#666666"
                        android:textSize="14sp"

                        />



                </LinearLayout>

            </RelativeLayout>


        </LinearLayout>

    </ScrollView>

</FrameLayout>