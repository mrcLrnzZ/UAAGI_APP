<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0F">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="490dp"
        app:cardBackgroundColor="@color/White"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.55">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/accentBar"
                android:layout_width="0dp"
                android:layout_height="5dp"
                android:background="@color/DarkBlue"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Close Button -->
            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close"
                app:tint="@color/DarkBlue"
                android:visibility="invisible"
                app:layout_constraintTop_toBottomOf="@id/accentBar"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Title -->

            <ImageView
                android:id="@+id/logo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="176dp"
                android:background="@color/White"
                android:contentDescription="Close"
                android:padding="8dp"
                android:src="@drawable/logout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/accentBar"
                app:tint="@color/DarkBlue" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="12dp"
                android:text="Sign Out?"
                android:textSize="22sp"
                android:textColor="@color/DarkBlue"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="0.01"
                app:layout_constraintTop_toBottomOf="@id/btnClose"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:layout_marginTop="10dp"
                android:text="You will be signed out of your account. You can sign back in at any time."
                android:textSize="14sp"
                android:textColor="@color/Black"
                android:alpha="0.6"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Separator -->
            <View
                android:id="@+id/separator"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginStart="28dp"
                android:layout_marginEnd="28dp"
                android:layout_marginTop="24dp"
                android:background="@color/DarkBlue"
                android:alpha="0.4"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="28dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="42dp"
                app:layout_constraintTop_toBottomOf="@id/separator">

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Stay logged in"
                    android:textSize="14sp"
                    android:textColor="#7A7A96"
                    android:background="@drawable/cancel_bg"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnSignOut"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="SIGN OUT"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/White"
                    android:letterSpacing="0.08"
                    android:background="@drawable/logout_bg"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>