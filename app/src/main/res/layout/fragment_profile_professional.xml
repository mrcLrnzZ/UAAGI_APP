<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/DarkBlue"
    tools:context=".ui.users.FragmentsHomePage.Profile">

    <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5F7FA"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Work Experiences -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWorkExperiences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Work Experiences"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="COMPANY"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="PREVIOUS JOB POSITION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="DESCRIPTION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/WorkCompany"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="TechNova Solutions, Inc."
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/WorkPosition"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Junior Software Developer"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/WorkDescription"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="Assisted in developing and maintaining web applications using HTML, CSS, and JavaScript."
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Certificates -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCertificates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Certificates"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <!-- Header Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="CERTIFICATION TITLE"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="ORGANIZATION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="DESCRIPTION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                            </LinearLayout>

                            <!-- Data Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/CertTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Introduction to Web Development"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/CertOrganization"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Online Learning Academy"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/CertDescription"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="This certification covers the fundamentals of web development, including HTML structure, CSS styling, and basic JavaScript functionality."
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Seminars & Trainings -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSeminars"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Seminars &amp; Trainings"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="TYPE"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="TITLE"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="DATE"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/SeminarType"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Seminar"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/SeminarTitle"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.5"
                                    android:text="Basic Programming and Problem-Solving Workshop"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/SeminarDate"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="November 30, 2024"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Skills & Qualifications -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSkills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Skills &amp; Qualifications"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="SKILL"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="DESCRIPTION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/SkillType"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Technical"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                                <TextView
                                    android:id="@+id/SkillDescription"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="Proficient in basic web development technologies including HTML, CSS, and JavaScript. Able to create responsive layouts, troubleshoot front-end issues, and follow coding best practices."
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />

                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginTop="12dp"
                                android:layout_marginBottom="12dp"
                                android:background="#E8ECF0" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="QUALIFICATION"
                                android:textColor="#8FA3B1"
                                android:textSize="10sp"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/Qualification"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Bachelor of Science in Computer Science (Undergraduate)"
                                android:textColor="#1A2E4A"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

</FrameLayout>