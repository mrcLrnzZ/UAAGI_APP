<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/DarkBlue"
    tools:context=".ui.users.FragmentsHomePage.Profile">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/DarkBlue"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RelativeLayout
                    android:id="@+id/layoutHeader"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="40dp"
                    android:background="@color/DarkBlue">

                    <TextView
                        android:id="@+id/ProfileTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="16dp"
                        android:text="Profile"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </RelativeLayout>

                <!-- Profile summary card -->
                <LinearLayout
                    android:id="@+id/layoutProfileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/layoutHeader"
                    android:layout_marginTop="-40dp"
                    android:background="@drawable/profile_card"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="95dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/FullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Angel Emie Jane Bien"
                        android:textColor="@color/DarkBlue"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/JobPosition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Software Engineer"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Profile Photo -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_alignBottom="@id/layoutHeader"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="-40dp"
                    android:background="@drawable/circle_white"
                    android:elevation="10dp"
                    android:padding="8dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_icon" />

            </RelativeLayout>

            <!-- info cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F5F7FA"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- personal info -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPersonalInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Personal Information"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- Last / First / Middle Name -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LAST NAME"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/tvLastName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Bien"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="FIRST NAME"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/tvFirstName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Angel Emie Jane"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="MIDDLE NAME"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/tvMiddleName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Pareja"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- DOB / Age / Gender -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DATE OF BIRTH"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Dob"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="July 26, 2005"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AGE"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Age"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="20"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GENDER"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Gender"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Female"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- Religion / Civil Status / Nationality -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RELIGION"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Religion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Protestant"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CIVIL STATUS"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/CivilStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Single"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="NATIONALITY"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Nationality"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Filipino"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- contact-->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardContactInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Information"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- Mobile / Tel -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="MOBILE NUMBER"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Mobile"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="09685413999"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="TELEPHONE NUMBER"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:id="@+id/Telephone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="123-567-234"
                                    android:textColor="#1A2E4A"
                                    android:textSize="14sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- Email -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL ADDRESS"
                            android:textColor="#8FA3B1"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />
                        <TextView
                            android:id="@+id/Email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="angelemiejane.bien@gmail.com"
                            android:textColor="#1A2E4A"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!--address-->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Address"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CURRENT ADDRESS"
                            android:textColor="#8FA3B1"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />
                        <TextView
                            android:id="@+id/CurrentAddr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="183 KKK Street, Bagong Barrio, Barangay 150, City of Caloocan, National Capital Region (NCR)"
                            android:textColor="#1A2E4A"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PERMANENT ADDRESS"
                            android:textColor="#8FA3B1"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />
                        <TextView
                            android:id="@+id/PermanentAddr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="183 KKK Street, Bagong Barrio, Barangay 150, City of Caloocan, National Capital Region (NCR)"
                            android:textColor="#1A2E4A"
                            android:textSize="14sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!--education-->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEducation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Education"
                            android:textColor="#1A3A5C"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="14dp"
                            android:background="#E8ECF0" />

                        <!-- Primary -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="PRIMARY SCHOOL NAME"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="YEAR GRADUATED"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="ACHIEVEMENT"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/PrimarySchool"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="Bagong Barrio Elementary High School"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/PrimaryYear"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="2017"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/PrimaryAward"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Top 9"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="#E8ECF0" />

                        <!-- High School -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="HIGH SCHOOL NAME"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="YEAR GRADUATED"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="ACHIEVEMENT"
                                    android:textColor="#8FA3B1"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.08" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/HighSchool"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="2"
                                    android:text="Bagong Barrio National High School"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/HighSchoolYear"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="2021"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                                <TextView
                                    android:id="@+id/HighSchoolAward"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="High Honors"
                                    android:textColor="#1A2E4A"
                                    android:textSize="13sp" />
                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="#E8ECF0" />

                        <!-- College -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#F8FAFB"
                            android:padding="12dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
