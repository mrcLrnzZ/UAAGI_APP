<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0F">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/White"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/DarkBlue">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.2"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-16dp"
                    android:layout_marginEnd="-16dp"/>

                <View
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.15"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="28dp"
                    android:layout_marginEnd="16dp"/>

                <View
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:background="@drawable/circle_background"
                    android:alpha="0.15"
                    android:layout_gravity="bottom|start"
                    android:layout_marginBottom="-16dp"
                    android:layout_marginStart="-16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="APPLICATION TIMELINE"
                            android:textColor="@color/LightBlue"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-medium"/>

                        <ImageView
                            android:id="@+id/ivCloseTimeline"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_close"
                            android:padding="6dp"
                            android:background="@drawable/circle_background_done"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/DarkBlue"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDialogJobTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Software Engineer"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/White"/>

                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/circle_red"
                                android:backgroundTint="@color/LightBlue"/>

                            <View
                                android:layout_width="2dp"
                                android:layout_height="44dp"
                                android:background="@color/DarkBlue"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginBottom="6dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:fontFamily="sans-serif-black"
                                android:text="Application Submitted"
                                android:textColor="@color/DarkBlue"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvTimelineAppliedDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Oct 24, 2023"
                                android:textColor="@color/Gray"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/circle_red"
                                android:backgroundTint="@color/LightBlue"/>

                            <View
                                android:layout_width="2dp"
                                android:layout_height="44dp"
                                android:background="@color/DarkBlue"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginBottom="6dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvViewedBy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:fontFamily="sans-serif-black"
                                android:text="Resume viewed by recruiter"
                                android:textColor="@color/DarkBlue"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvTimelineDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Oct 26, 2023"
                                android:textColor="@color/Gray"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/circle_red"
                                android:backgroundTint="@color/LightBlue"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTimelineStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="2dp"
                                android:fontFamily="sans-serif-black"
                                android:text="Status updated to 'Shortlisted'"
                                android:textColor="@color/DarkBlue"
                                android:textSize="13sp"/>

                            <TextView
                                android:id="@+id/tvHasViewed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Not yet viewed"
                                android:textColor="@color/Gray"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutInterviewActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/PaleBlue"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@color/PaleBlue"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="10dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/LightBlue"/>

                        <TextView
                            android:id="@+id/tvInterviewTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Your interview is scheduled for Nov 5, 2023 at 10:00 AM"
                            android:textColor="@color/DarkBlue"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddToCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:backgroundTint="@color/DarkBlue"
                        android:fontFamily="sans-serif-medium"
                        android:text="Add to Calendar"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_calendar"/>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>